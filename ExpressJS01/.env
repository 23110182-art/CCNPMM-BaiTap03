# ==================================================
# APP
# ==================================================
NODE_ENV=development
PORT=8080

# ==================================================
# DATABASE TYPE
# Chọn:
# mongodb
# mysql
# ==================================================
DB_TYPE=mongodb

# ==================================================
# MONGODB
# ==================================================
MONGO_DB_URL=mongodb://localhost:27017/fullstack01

# ==================================================
# MYSQL
# ==================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=fullstack01

# ==================================================
# JWT
# ==================================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=1d